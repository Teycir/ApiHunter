{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ApiHunter Desktop",
  "version": "0.1.0",
  "identifier": "com.apihunter.desktop",
  "build": {
    "beforeDevCommand": "npm run build",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ApiHunter Desktop",
        "width": 1200,
        "height": 820,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
